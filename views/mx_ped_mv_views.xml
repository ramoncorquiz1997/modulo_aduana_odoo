<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ═══════════════════════════════════════════════════════════════════════
         VISTAS — mx.ped.mv  (Manifestación de Valor)
    ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- List view de la cabecera MV -->
    <record id="view_mx_ped_mv_list" model="ir.ui.view">
      <field name="name">mx.ped.mv.list</field>
      <field name="model">mx.ped.mv</field>
      <field name="arch" type="xml">
        <list string="Manifestaciones de Valor" default_order="id desc"
              decoration-success="estatus == 'registrada'"
              decoration-warning="estatus == 'firmada'"
              decoration-danger="estatus == 'error'"
              decoration-muted="estatus == 'borrador'">
          <field name="numero_mv"/>
          <field name="e_document_mv"/>
          <field name="operacion_id"/>
          <field name="rfc_importador"/>
          <field name="estatus" widget="badge"
                 decoration-success="estatus == 'registrada'"
                 decoration-warning="estatus in ('firmada','enviada')"
                 decoration-danger="estatus == 'error'"/>
          <field name="cove_count" string="COVEs"/>
          <field name="total_valor_aduana" string="Valor en aduana"/>
          <field name="fecha_registro"/>
        </list>
      </field>
    </record>

    <!-- Form view de la cabecera MV -->
    <record id="view_mx_ped_mv_form" model="ir.ui.view">
      <field name="name">mx.ped.mv.form</field>
      <field name="model">mx.ped.mv</field>
      <field name="arch" type="xml">
        <form string="Manifestación de Valor">

          <!-- Barra de estado -->
          <header>
            <button name="action_cargar_coves"
                    string="↺ Recargar COVEs"
                    type="object"
                    invisible="estatus != 'borrador'"
                    help="Descarta las líneas actuales y vuelve a cargar los COVEs de la operación"/>
            <button name="action_firmar"
                    string="Firmar"
                    type="object"
                    class="btn-primary"
                    invisible="estatus != 'borrador'"/>
            <button name="action_enviar_vucem"
                    string="Enviar a VUCEM"
                    type="object"
                    class="btn-primary"
                    invisible="estatus not in ('firmada','error')"/>
            <button name="action_consultar_vucem"
                    string="Consultar en VUCEM"
                    type="object"
                    invisible="not numero_mv"/>
            <button name="action_actualizar_mv"
                    string="Actualizar MV"
                    type="object"
                    invisible="not numero_mv"/>
            <field name="estatus" widget="statusbar"
                   statusbar_visible="borrador,firmada,enviada,registrada"/>
          </header>

          <sheet>
            <!-- Botones stat -->
            <div class="oe_button_box" name="button_box">
              <button name="action_view_logs"
                      type="object"
                      class="oe_stat_button"
                      icon="fa-list-alt">
                <field name="log_count" widget="statinfo" string="Logs"/>
              </button>
            </div>

            <!-- Encabezado -->
            <div class="oe_title">
              <label for="numero_mv" string="Número de operación VUCEM"/>
              <h1>
                <field name="numero_mv" placeholder="(asignado por VUCEM al registrar)" readonly="1"/>
              </h1>
              <label for="e_document_mv" string="e-Document MV"/>
              <h2>
                <field name="e_document_mv" placeholder="ej. MNVA250002S37" readonly="1"/>
              </h2>
            </div>

            <group>
              <group string="Identificación">
                <field name="operacion_id" readonly="estatus != 'borrador'"/>
                <field name="rfc_importador" readonly="estatus != 'borrador'"/>
                <field name="credencial_id"/>
                <field name="company_id" invisible="1"/>
              </group>
              <group string="Estatus VUCEM">
                <field name="estatus_vucem" readonly="1"/>
                <field name="fecha_envio" readonly="1"/>
                <field name="fecha_registro" readonly="1"/>
              </group>
            </group>

            <!-- Personas consulta -->
            <notebook>
              <page string="COVEs y Valoración" name="coves">
                <field name="cove_line_ids"
                       readonly="estatus not in ('borrador',)"
                       widget="one2many_list"
                       mode="list">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="cove_id" required="1"/>
                    <field name="e_document_cove" readonly="1"/>
                    <field name="incoterm" required="1"/>
                    <field name="existe_vinculacion"/>
                    <field name="metodo_valoracion" required="1"/>
                  </list>
                </field>
              </page>

              <page string="Personas consulta" name="personas">
                <field name="persona_consulta_ids"
                       readonly="estatus not in ('borrador',)">
                  <list editable="bottom">
                    <field name="rfc" required="1"/>
                    <field name="tipo_figura" required="1"/>
                  </list>
                </field>
              </page>

              <page string="Valor en Aduana" name="valor_aduana">
                <div class="alert alert-warning mb-2"
                     invisible="not aviso_multicurrency">
                  <field name="aviso_multicurrency" readonly="1" nolabel="1"/>
                </div>
                <group>
                  <group string="Totales en MXN (importe × tipo de cambio)">
                    <field name="total_precio_pagado" digits="[19,3]"/>
                    <field name="total_precio_por_pagar" digits="[19,3]"/>
                    <field name="total_incrementables" digits="[19,3]"/>
                    <field name="total_decrementables" digits="[19,3]"/>
                    <field name="total_valor_aduana" digits="[19,3]"/>
                    <field name="currency_id" invisible="1"/>
                  </group>
                </group>
              </page>

              <page string="Firma Electrónica" name="firma"
                    groups="base.group_system">
                <group>
                  <field name="cadena_original" readonly="1" widget="text"/>
                  <field name="certificado_b64" readonly="1" widget="text"/>
                  <field name="firma_b64" readonly="1" widget="text"/>
                </group>
              </page>

              <page string="Notas" name="notas">
                <field name="notes" placeholder="Observaciones internas…"/>
              </page>
            </notebook>
          </sheet>

          <chatter/>
        </form>
      </field>
    </record>

    <!-- Search view MV -->
    <record id="view_mx_ped_mv_search" model="ir.ui.view">
      <field name="name">mx.ped.mv.search</field>
      <field name="model">mx.ped.mv</field>
      <field name="arch" type="xml">
        <search string="Buscar MV">
          <field name="numero_mv" string="Núm. operación"/>
          <field name="e_document_mv" string="e-Document"/>
          <field name="rfc_importador" string="RFC Importador"/>
          <field name="operacion_id" string="Operación"/>
          <filter name="borrador" string="Borrador" domain="[('estatus','=','borrador')]"/>
          <filter name="firmada" string="Firmada" domain="[('estatus','=','firmada')]"/>
          <filter name="registrada" string="Registrada" domain="[('estatus','=','registrada')]"/>
          <filter name="error" string="Con error" domain="[('estatus','=','error')]"/>
          <separator/>
          <group expand="0" string="Agrupar por">
            <filter name="group_estatus" string="Estatus" context="{'group_by':'estatus'}"/>
            <filter name="group_operacion" string="Operación" context="{'group_by':'operacion_id'}"/>
          </group>
        </search>
      </field>
    </record>

    <!-- Action principal -->
    <record id="action_mx_ped_mv" model="ir.actions.act_window">
      <field name="name">Manifestaciones de Valor</field>
      <field name="res_model">mx.ped.mv</field>
      <field name="view_mode">list,form</field>
      <field name="search_view_id" ref="view_mx_ped_mv_search"/>
      <field name="context">{'search_default_registrada': 0}</field>
    </record>


    <!-- ═══════════════════════════════════════════════════════════════════════
         VISTAS — mx.ped.mv.cove  (detalle por COVE — form embebido)
    ═══════════════════════════════════════════════════════════════════════════ -->

    <record id="view_mx_ped_mv_cove_form" model="ir.ui.view">
      <field name="name">mx.ped.mv.cove.form</field>
      <field name="model">mx.ped.mv.cove</field>
      <field name="arch" type="xml">
        <form string="COVE en MV">
          <sheet>
            <group>
              <group string="Identificación COVE">
                <field name="cove_id" required="1"/>
                <field name="e_document_cove" readonly="1"/>
                <field name="incoterm" required="1"/>
                <field name="existe_vinculacion"/>
                <field name="metodo_valoracion" required="1"/>
              </group>
            </group>

            <notebook>
              <!-- Pedimentos relacionados -->
              <page string="Pedimentos relacionados" name="pedimentos">
                <field name="pedimento_ids">
                  <list editable="bottom">
                    <field name="numero_pedimento"/>
                    <field name="patente"/>
                    <field name="aduana"/>
                  </list>
                </field>
              </page>

              <!-- Precio pagado -->
              <page string="Precio pagado" name="precio_pagado">
                <field name="precio_pagado_ids">
                  <list editable="bottom">
                    <field name="fecha_pago" required="1"/>
                    <field name="total" required="1" digits="[19,3]"/>
                    <field name="tipo_pago" required="1"/>
                    <field name="especifique"
                           invisible="tipo_pago != 'FORPAG.OT'"/>
                    <field name="tipo_moneda" required="1"/>
                    <field name="tipo_cambio" required="1" digits="[16,3]"/>
                  </list>
                </field>
              </page>

              <!-- Precio por pagar -->
              <page string="Precio por pagar" name="precio_por_pagar">
                <field name="precio_por_pagar_ids">
                  <list editable="bottom">
                    <field name="fecha_pago" required="1"/>
                    <field name="total" required="1" digits="[19,3]"/>
                    <field name="situacion_no_fecha_pago"/>
                    <field name="tipo_pago" required="1"/>
                    <field name="especifique"
                           invisible="tipo_pago != 'FORPAG.OT'"/>
                    <field name="tipo_moneda" required="1"/>
                    <field name="tipo_cambio" required="1" digits="[16,3]"/>
                  </list>
                </field>
              </page>

              <!-- Compensaciones de pago -->
              <page string="Compensaciones de pago" name="compenso_pago">
                <field name="compenso_pago_ids">
                  <list editable="bottom">
                    <field name="tipo_pago" required="1"/>
                    <field name="especifique"
                           invisible="tipo_pago != 'FORPAG.OT'"/>
                    <field name="fecha" required="1"/>
                    <field name="motivo" required="1"/>
                    <field name="prestacion_mercancia" required="1"/>
                  </list>
                </field>
              </page>

              <!-- Incrementables -->
              <page string="Incrementables" name="incrementables">
                <field name="incrementable_ids">
                  <list editable="bottom">
                    <field name="tipo_incrementable" required="1"/>
                    <field name="fecha_erogacion" required="1"/>
                    <field name="importe" required="1" digits="[19,3]"/>
                    <field name="tipo_moneda" required="1"/>
                    <field name="tipo_cambio" required="1" digits="[16,3]"/>
                    <field name="a_cargo_importador"/>
                  </list>
                </field>
              </page>

              <!-- Decrementables -->
              <page string="Decrementables" name="decrementables">
                <field name="decrementable_ids">
                  <list editable="bottom">
                    <field name="tipo_decrementable" required="1"/>
                    <field name="fecha_erogacion" required="1"/>
                    <field name="importe" required="1" digits="[19,3]"/>
                    <field name="tipo_moneda" required="1"/>
                    <field name="tipo_cambio" required="1" digits="[16,3]"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════════════════════
         MENÚ
    ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- Menú raíz MV (hijo de la raíz de operaciones, como está el COVE) -->
    <menuitem id="menu_mx_ped_mv_root"
              name="Manifestaciones de Valor"
              parent="modulo_aduana_odoo.mx_ped_operacion_menu_root"
              sequence="25"/>

    <menuitem id="menu_mx_ped_mv_list"
              name="MVs"
              parent="menu_mx_ped_mv_root"
              action="action_mx_ped_mv"
              sequence="10"/>

  </data>
</odoo>
