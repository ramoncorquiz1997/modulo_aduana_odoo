<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="mx_ped_validacion_wizard_view_form" model="ir.ui.view">
      <field name="name">mx.ped.validacion.wizard.form</field>
      <field name="model">mx.ped.validacion.wizard</field>
      <field name="arch" type="xml">
        <form string="Validación de Pedimento">
          <sheet>

            <!-- Resumen en banner -->
            <div class="alert alert-danger mb-3" attrs="{'invisible': [('tiene_errores', '=', False)]}">
              <i class="fa fa-times-circle me-2"/>
              <strong><field name="resumen" readonly="1"/></strong>
              &amp;nbsp; Corrija los errores antes de exportar el archivo TXT.
            </div>
            <div class="alert alert-warning mb-3" attrs="{'invisible': ['|', ('tiene_errores', '=', True), ('tiene_advertencias', '=', False)]}">
              <i class="fa fa-exclamation-triangle me-2"/>
              <strong><field name="resumen" readonly="1"/></strong>
              &amp;nbsp; Puede exportar pero se recomienda revisar las advertencias.
            </div>
            <div class="alert alert-success mb-3" attrs="{'invisible': ['|', ('tiene_errores', '=', True), ('tiene_advertencias', '=', True)]}">
              <i class="fa fa-check-circle me-2"/>
              <strong><field name="resumen" readonly="1"/></strong>
            </div>

            <!-- Contadores rápidos -->
            <group col="4">
              <field name="operacion_id" readonly="1"/>
              <field name="total_errores" readonly="1" string="Errores"/>
              <field name="total_advertencias" readonly="1" string="Advertencias"/>
            </group>

            <!-- Tabla de resultados -->
            <field name="linea_ids" readonly="1" nolabel="1">
              <tree decoration-danger="severidad == 'error'"
                    decoration-warning="severidad == 'advertencia'"
                    decoration-info="severidad == 'info'"
                    default_order="severidad_order asc, categoria asc, sequence asc">
                <field name="severidad" widget="badge"
                       decoration-danger="severidad == 'error'"
                       decoration-warning="severidad == 'advertencia'"
                       decoration-info="severidad == 'info'"/>
                <field name="categoria"/>
                <field name="referencia"/>
                <field name="mensaje"/>
                <field name="severidad_order" column_invisible="1"/>
                <field name="sequence" column_invisible="1"/>
              </tree>
            </field>

          </sheet>
          <footer>
            <button name="action_exportar_txt"
                    type="object"
                    string="Exportar TXT"
                    class="btn-primary"
                    attrs="{'invisible': [('tiene_errores', '=', True)]}"/>
            <button name="action_exportar_proforma"
                    type="object"
                    string="Proforma PDF"
                    class="btn-secondary"
                    attrs="{'invisible': [('tiene_errores', '=', True)]}"/>
            <button string="Cerrar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

  </data>
</odoo>
