<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>


    <record id="crm_lead_view_form_inherit_mi_modulo_aduana" model="ir.ui.view">
      <field name="name">crm.lead.form.inherit.modulo_aduana_odoo.aduana</field>
      <field name="model">crm.lead</field>
      <field name="inherit_id" ref="crm.crm_lead_view_form"/>
      <field name="arch" type="xml">
        <!-- Ajustes UX para caso aduanal -->
        <xpath expr="//field[@name='name']" position="attributes">
          <attribute name="readonly">0</attribute>
        </xpath>
        <xpath expr="//field[@name='partner_id']" position="attributes">
          <attribute name="string">Cliente</attribute>
        </xpath>
        <xpath expr="//field[@name='user_id']" position="attributes">
          <attribute name="string">Encargado operativo</attribute>
        </xpath>
        <xpath expr="//div[.//field[@name='expected_revenue'] and .//field[@name='probability']]" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='expected_revenue']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='probability']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='date_deadline']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='tag_ids']" position="attributes">
          <attribute name="invisible">1</attribute>
        </xpath>

        <!-- SMART BUTTON -->
        <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
          <button type="action"
                  name="%(modulo_aduana_odoo.mx_ped_operacion_action)d"
                  class="oe_stat_button"
                  icon="fa-file-text-o"
                  context="{'search_default_lead_id': id}">
            <field string="Pedimentos" name="x_ped_operacion_count" widget="statinfo"/>
          </button>
        </xpath>

        <!-- BOTÓN EN HEADER -->
        <xpath expr="//header" position="inside">
          <button name="action_crear_pedimento" type="object" string="Crear / Actualizar pedimento" class="btn-secondary"/>
        </xpath>

        <xpath expr="//notebook" position="inside">

          <page string="Operación" name="mi_modulo_operacion">
            <group>
              <group string="Identificación">
                <field name="x_tipo_operacion"/>
                <field name="x_folio_operacion"/>
                <field name="x_referencia_cliente"/>
                <field name="x_prioridad_operativa"/>
              </group>
              <group string="Responsables">
                <field name="x_ejecutivo_id"/>
                <field name="user_id"/>
                <field name="partner_id"/>
              </group>
            </group>
          </page>

          <page string="Aduana" name="mi_modulo_aduana">
            <group>
              <group string="Clasificación">
                <field name="x_regimen"/>
                <field name="x_tipo_despacho"/>
                <field name="x_aduana_seccion_despacho_id"/>
                <field name="x_aduana" readonly="1"/>
                <field name="x_aduana_seccion_entrada_salida_id"/>
                <field name="x_agente_aduanal_id" domain="[('x_contact_role','=','agente_aduanal')]"/>
                <field name="x_patente_agente" readonly="1"/>
                <field name="x_curp_agente"/>
                <field name="x_clave_pedimento_id"
                       domain="[('active','=',True), '|', ('tipo_operacion','=','ambas'), ('tipo_operacion','=',x_tipo_operacion), '|', ('regimen','=','cualquiera'), ('regimen','=',x_regimen)]"/>
                <field name="x_acuse_validacion"/>
              </group>
            </group>
          </page>

          

          <page string="Partes" name="mi_modulo_partes">
            <group>
              <group string="Participantes">
                <field name="x_exportador_id"
                       domain="[('x_contact_role','in',['cliente','otro'])]"
                       invisible="x_tipo_operacion == 'importacion'"
                       required="x_tipo_operacion == 'exportacion'"/>
                <field name="x_exportador_name"
                       invisible="x_tipo_operacion == 'importacion'"/>
                <field name="x_importador_id"
                       domain="[('x_contact_role','in',['cliente','otro'])]"
                       invisible="x_tipo_operacion == 'exportacion'"
                       required="x_tipo_operacion == 'importacion'"/>
                <field name="x_importador_name"
                       invisible="x_tipo_operacion == 'exportacion'"/>
                <field name="x_proveedor_id"
                       domain="['|', ('x_contact_role','in',['proveedor','otro']), ('supplier_rank','>',0)]"
                       context="{'default_x_contact_role': 'proveedor'}"/>
                <field name="x_proveedor_name"/>
                <field name="x_comprador_id"
                       domain="[('x_contact_role','in',['cliente','otro'])]"
                       invisible="x_tipo_operacion == 'importacion'"
                       required="x_tipo_operacion == 'exportacion'"/>
                <field name="x_comprador_name"
                       invisible="x_tipo_operacion == 'importacion'"/>
              </group>
              <group string="Destino">
                <field name="x_consignatario_name"/>
                <field name="x_destinatario_final_name"/>
              </group>
            </group>
          </page>

          <page string="Logística" name="mi_modulo_logistica">
            <group>
              <group string="Ruta">
                <field name="x_modo_transporte"/>
                <field name="x_incoterm"/>
                <field name="x_medio_transporte_salida_id"/>
                <field name="x_medio_transporte_arribo_id"/>
                <field name="x_medio_transporte_entrada_salida_id"/>
                <field name="x_origen_destino_id"/>
                <field name="x_pais_origen_id"
                       invisible="x_tipo_operacion == 'exportacion'"/>
                <field name="x_pais_destino_id"
                       invisible="x_tipo_operacion == 'importacion'"/>
                <field name="x_lugar_carga"/>
                <field name="x_lugar_descarga"/>
              </group>
            </group>
          </page>

          <page string="Transporte" name="mi_modulo_transporte">
            <group>

              <!-- ══ DOCUMENTOS DE TRANSPORTE ══════════════════════════════ -->
              <group string="Documentos de transporte">

                <!-- Marítimo: BL + booking -->
                <group invisible="x_modo_transporte != 'maritimo'">
                  <field name="x_bl_file" filename="x_bl_filename" string="Archivo B/L (PDF)"/>
                  <field name="x_bl_filename" invisible="1"/>
                  <field name="x_bl_last_read" readonly="1" string="Última lectura B/L"/>
                  <field name="x_booking" string="Booking #"/>
                </group>

                <!-- Aéreo: AWB / guía aérea -->
                <group invisible="x_modo_transporte != 'aereo'">
                  <field name="x_bl_file" filename="x_bl_filename" string="Archivo AWB (PDF)"/>
                  <field name="x_bl_filename" invisible="1"/>
                  <field name="x_bl_last_read" readonly="1" string="Última lectura AWB"/>
                </group>

                <!-- Terrestre/ferro: carta de porte -->
                <group invisible="x_modo_transporte not in ('terrestre', 'ferro')">
                  <field name="x_bl_file" filename="x_bl_filename" string="Carta de porte / guía (PDF)"/>
                  <field name="x_bl_filename" invisible="1"/>
                  <field name="x_bl_last_read" readonly="1"/>
                </group>

              </group>

              <!-- ══ TRANSPORTISTAS (Reg. 502) ══════════════════════════════ -->
              <group string="Transportistas (Reg. 502)">
                <field name="x_transportista_ids" nolabel="1"
                       context="{'default_lead_id': id}">
                  <list editable="bottom" open_form_view="1">
                    <!-- NOTA: column_invisible se evalúa contra el padre (crm.lead),
                         por eso usamos x_modo_transporte (campo del lead) aquí.
                         invisible en las celdas de fila usa el contexto de la línea. -->
                    <field name="sequence" widget="handle"/>
                    <field name="transportista_id"
                           domain="[('x_contact_role','=','transportista')]"
                           context="{'default_x_contact_role': 'transportista', 'default_company_type': 'company'}"
                           string="Carrier / Transportista"/>
                    <field name="transporte_identificador"
                           string="Placa / Matrícula / Buque"
                           optional="show"/>
                    <field name="numero_vuelo"
                           column_invisible="x_modo_transporte != 'aereo'"
                           optional="show"/>
                    <field name="nombre_buque"
                           column_invisible="x_modo_transporte != 'maritimo'"
                           optional="show"/>
                    <field name="numero_viaje"
                           column_invisible="x_modo_transporte != 'maritimo'"
                           optional="show"/>
                    <field name="transporte_pais_id" string="País"/>
                    <field name="es_carrier_nacional" optional="hide"/>
                    <field name="rfc" readonly="1"
                           column_invisible="x_modo_transporte not in ('terrestre', 'ferro')"
                           optional="show"/>
                    <field name="curp" readonly="1"
                           column_invisible="x_modo_transporte not in ('terrestre', 'ferro')"
                           optional="hide"/>
                  </list>
                  <form string="Transportista">
                    <!-- modo_transporte es un related field en la línea,
                         aquí invisible se evalúa en el contexto de crm.lead.transportista -->
                    <group>
                      <field name="modo_transporte" invisible="1"/>
                      <group string="Carrier">
                        <field name="sequence"/>
                        <field name="transportista_id"
                               domain="[('x_contact_role','=','transportista')]"
                               context="{'default_x_contact_role': 'transportista', 'default_company_type': 'company'}"
                               string="Carrier / Transportista"/>
                        <field name="transporte_pais_id" string="País del carrier"/>
                        <field name="es_carrier_nacional"/>
                      </group>
                      <group string="Identificación del vehículo">
                        <!-- Un solo campo transporte_identificador, label genérico -->
                        <field name="transporte_identificador"
                               string="Placas / Matrícula / ID vehículo"/>
                        <!-- Campos adicionales solo para aéreo -->
                        <field name="numero_vuelo"
                               invisible="modo_transporte != 'aereo'"/>
                        <!-- Campos adicionales solo para marítimo -->
                        <field name="nombre_buque"
                               invisible="modo_transporte != 'maritimo'"/>
                        <field name="numero_viaje"
                               invisible="modo_transporte != 'maritimo'"/>
                      </group>
                      <group string="Datos del carrier (auto desde contacto)"
                             invisible="not es_carrier_nacional">
                        <field name="rfc" readonly="1"/>
                        <field name="curp" readonly="1"
                               invisible="modo_transporte not in ('terrestre', 'ferro')"/>
                        <field name="nombre" readonly="1"/>
                        <field name="domicilio" readonly="1"/>
                      </group>
                      <group string="Datos del carrier (internacional)"
                             invisible="es_carrier_nacional">
                        <field name="nombre" readonly="1" string="Nombre / Razón social"/>
                      </group>
                    </group>
                  </form>
                </field>
              </group>

              <!-- ══ GUÍAS / MANIFIESTOS (Reg. 503) ════════════════════════
                   Una sola instancia del campo — el título y las columnas
                   actúan según el modo seleccionado en el lead.         -->
              <group string="AWB / BL / Guías (Reg. 503)">
                <field name="x_guia_ids" nolabel="1"
                       context="{'default_lead_id': id}">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="tipo_documento"/>
                    <field name="numero" string="Número"/>
                    <field name="identificador" string="Nivel" optional="hide"/>
                  </list>
                </field>
              </group>

              <!-- ══ CONTENEDORES (Reg. 504) — Solo marítimo/ferro ════════ -->
              <group string="Contenedores (Reg. 504)"
                     invisible="x_modo_transporte not in ('maritimo', 'ferro')">
                <field name="x_contenedor_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="numero" string="Número contenedor"/>
                    <field name="tipo_contenedor_id"/>
                  </list>
                </field>
              </group>

              <!-- ══ CANDADOS / SELLOS (Reg. 516) — Solo terrestre/ferro ══ -->
              <group string="Candados / Sellos (Reg. 516)"
                     invisible="x_modo_transporte not in ('terrestre', 'ferro')">
                <field name="x_candado_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="transporte_identificador" string="Placa / Furgón"/>
                    <field name="num_candado" string="Número de candado/sello"/>
                  </list>
                </field>
              </group>

            </group>
          </page>

          <page string="Fechas" name="mi_modulo_fechas">
            <group>
              <group string="Fechas estimadas (planeacion)">
                <field name="x_fecha_estimada_salida"/>
                <field name="x_fecha_estimada_arribo"/>
                <field name="x_fecha_recoleccion"/>
                <field name="x_fecha_entrega"/>
              </group>
              <group string="Fechas reales de operacion">
                <field name="x_fecha_cruce"
                       invisible="x_modo_transporte in ('aereo', 'maritimo')"/>
                <field name="x_fecha_zarpe"
                       invisible="x_modo_transporte != 'maritimo'"/>
                <field name="x_fecha_vuelo"
                       invisible="x_modo_transporte != 'aereo'"/>
              </group>
              <group string="Fechas aduanales">
                <field name="x_fecha_pago_pedimento"/>
                <field name="x_fecha_liberacion"/>
                <field name="x_num_pedimento"/>
              </group>
            </group>
            <group string="Fechas oficiales a declarar (una por tipo)">
              <field name="x_fecha_506_ids" context="{'default_lead_id': id}">
                <list editable="bottom">
                  <field name="sequence" optional="hide"/>
                  <field name="tipo_fecha_code"/>
                  <field name="fecha"/>
                  <field name="notes"/>
                </list>
                <form string="Fecha declarable">
                  <group>
                    <field name="sequence"/>
                    <field name="tipo_fecha_code"/>
                    <field name="fecha"/>
                    <field name="notes"/>
                  </group>
                </form>
              </field>
            </group>
          </page>

          <page string="Documentos" name="mi_modulo_documentos">
            <group>
              <group string="Estado documental">
                <field name="x_doc_panel_status"
                       widget="badge"
                       readonly="1"
                       decoration-success="x_doc_panel_status == 'completo'"
                       decoration-warning="x_doc_panel_status == 'parcial'"
                       decoration-danger="x_doc_panel_status == 'incompleto'"/>
                <field name="x_doc_panel_score" readonly="1"/>
                <field name="x_doc_alert_count" readonly="1"/>
                <field name="x_docs_completos" readonly="1"/>
                <field name="x_doc_pendientes_auto" readonly="1"/>
              </group>
              <group string="Portal">
                <field name="x_visible_portal"/>
                <field name="x_ped_preflight_state"
                       widget="badge"
                       readonly="1"
                       decoration-success="x_ped_preflight_state == 'listo'"
                       decoration-danger="x_ped_preflight_state == 'incompleto'"/>
                <field name="x_ped_preflight_message" readonly="1"/>
              </group>
            </group>

            <group>
              <group string="Checklist aduanal">
                <field name="x_docs_requeridos_ids" widget="many2many_tags"/>
                <field name="x_docs_faltantes_text" placeholder="Ej. Falta packing list firmado, carta de instrucciones, BL original..."/>
              </group>
              <group string="Estado de documentos (automatico)">
                <field name="x_doc_bl_ok" readonly="1"/>
                <field name="x_doc_factura_pdf_ok" readonly="1"/>
                <field name="x_doc_factura_xml_ok" readonly="1"/>
                <field name="x_doc_cfdi_ok" readonly="1"/>
                <field name="x_counterparty_role_505" string="Tipo de contraparte comercial" readonly="1"/>
                <field name="x_counterparty_partner_id" string="Contraparte comercial" readonly="1"/>
                <field name="x_counterparty_name_505" string="Nombre comercial" readonly="1"/>
              </group>
            </group>

            <group>
              <group string="Validacion CFDI">
                <field name="x_factura_pdf_file" filename="x_factura_pdf_filename"/>
                <field name="x_factura_pdf_filename"/>
                <field name="x_factura_xml_file" filename="x_factura_xml_filename"/>
                <field name="x_factura_xml_filename"/>
                <field name="x_cfdi_validacion_estado"
                       widget="badge"
                       readonly="1"
                       decoration-success="x_cfdi_validacion_estado in ('valido_local', 'no_aplica')"
                       decoration-warning="x_cfdi_validacion_estado == 'pendiente'"
                       decoration-danger="x_cfdi_validacion_estado == 'invalido_local'"/>
                <field name="x_cfdi_validacion_mensaje" readonly="1"/>
                <field name="x_cfdi_validado_el" readonly="1"/>
              </group>
              <group string="Lectura base CFDI" invisible="x_documento_505_ids">
                <field name="x_cfdi_uuid" readonly="1"/>
                <field name="x_cfdi_rfc_emisor" readonly="1"/>
                <field name="x_cfdi_rfc_receptor" readonly="1"/>
                <field name="x_cfdi_total" readonly="1"/>
                <field name="x_cfdi_fecha_emision" readonly="1"/>
                <field name="x_cfdi_fecha" readonly="1"/>
                <field name="x_cfdi_numero" readonly="1"/>
                <field name="x_cfdi_termino_facturacion" readonly="1"/>
                <field name="x_cfdi_moneda_id" readonly="1"/>
                <field name="x_cfdi_valor_usd" readonly="1"/>
                <field name="x_cfdi_valor_moneda" readonly="1"/>
                <field name="x_cfdi_pais_id" readonly="1"/>
                <field name="x_cfdi_estado_id" readonly="1"/>
                <field name="x_cfdi_id_fiscal" readonly="1"/>
              </group>
            </group>

            <group string="Facturas / CFDI / Documentos comerciales">
              <field name="x_documento_505_ids" context="{'default_lead_id': id, 'default_tipo': 'factura'}">
                <list editable="bottom" delete="0"
                      decoration-danger="has_difference"
                      decoration-success="not has_difference and cfdi_valor_moneda > 0">
                  <field name="sequence" optional="hide"/>
                  <field name="tipo"/>
                  <field name="folio"/>
                  <field name="fecha"/>
                  <field name="cfdi_moneda_id" string="Moneda" optional="show"/>
                  <field name="cfdi_valor_moneda" string="Valor factura"/>
                  <field name="linked_valor_moneda" string="Amparado" readonly="1"/>
                  <field name="saldo_valor_moneda" string="Pendiente" readonly="1"/>
                  <field name="has_difference" column_invisible="1"/>
                  <field name="estatus" widget="badge"
                         decoration-success="estatus == 'ok'"
                         decoration-warning="estatus == 'pendiente'"
                         decoration-danger="estatus == 'rechazado'"/>
                  <button name="action_open_full_form" type="object"
                          string="Ver detalle" class="btn-link" icon="fa-external-link"/>
                </list>
                <form string="Documento comercial">
                  <group>
                    <group string="Captura basica">
                      <field name="tipo"/>
                      <field name="folio"/>
                      <field name="fecha"/>
                      <field name="es_documento_principal"/>
                      <field name="archivo_file" filename="archivo_filename"/>
                      <field name="archivo_filename" invisible="1"/>
                      <field name="estatus"/>
                      <field name="notas"/>
                    </group>
                    <group string="Datos comerciales">
                      <field name="linked_partida_count" readonly="1"/>
                      <field name="linked_valor_usd" readonly="1"/>
                      <field name="linked_valor_moneda" readonly="1"/>
                      <field name="saldo_valor_usd" readonly="1"/>
                      <field name="saldo_valor_moneda" readonly="1"/>
                      <field name="diferencia_valor_usd" readonly="1"/>
                      <field name="diferencia_valor_moneda" readonly="1"/>
                      <field name="cfdi_termino_facturacion" readonly="1"/>
                      <field name="cfdi_moneda_id"/>
                      <field name="cfdi_valor_usd"/>
                      <field name="cfdi_valor_moneda"/>
                      <field name="cfdi_pais_id" readonly="1"/>
                      <field name="cfdi_estado_id" readonly="1"/>
                      <field name="cfdi_id_fiscal" readonly="1"/>
                      <field name="counterparty_name_505" readonly="1"/>
                      <field name="counterparty_street_505" readonly="1"/>
                      <field name="counterparty_num_int_505" readonly="1"/>
                      <field name="counterparty_num_ext_505" readonly="1"/>
                      <field name="counterparty_zip_505" readonly="1"/>
                      <field name="counterparty_city_505" readonly="1"/>
                    </group>
                  </group>
                </form>
              </field>
            </group>
          </page>

          <page string="Importación" name="mi_modulo_importacion"
                invisible="x_tipo_operacion != 'importacion'">

            <group>
              <group string="Compra / proveedor">
                <field name="x_purchase_order"/>
                <field name="x_proveedor_invoice_number"/>
                <field name="x_condiciones_pago"/>
                <field name="x_tipo_compra"/>
                <field name="x_tratado_aplicable"/>
                <field name="x_pedimento_rectificacion"/>
                <field name="x_es_rectificacion"/>
                <field name="x_rect_pedimento_original" invisible="not x_es_rectificacion" required="x_es_rectificacion"/>
                <field name="x_rect_fecha_pago_original" invisible="not x_es_rectificacion" required="x_es_rectificacion"/>
                <field name="x_rect_patente_original" invisible="not x_es_rectificacion"/>
                <field name="x_rect_aduana_original_id" invisible="not x_es_rectificacion"/>
              </group>
              <group string="Resumen regulatorio (desde partidas)">
                <field name="x_resumen_permisos" readonly="1"/>
                <field name="x_resumen_rrna" readonly="1"/>
                <field name="x_resumen_noms" readonly="1"/>
                <field name="x_resumen_etiquetado" readonly="1"/>
                <button name="action_migrar_importacion_legacy"
                        type="object"
                        string="Migrar datos legacy a partidas"
                        class="btn-secondary"/>
                <field name="x_permisos_ids" widget="many2many_tags" invisible="1"/>
                <field name="x_normas_noms_text" invisible="1"/>
                <field name="x_etiquetado" invisible="1"/>
                <field name="x_cumplimiento_noms" invisible="1"/>
                <field name="x_certificado_origen"/>
              </group>
            </group>

            <group>
              <group string="Impuestos (estimados)">
                <field name="x_override_estimados"/>
                <field name="x_iva_estimado"/>
                <field name="x_igi_estimado"/>
                <field name="x_dta_estimado"/>
                <field name="x_prv_estimado"/>
                <field name="x_total_impuestos_estimado"/>
                <field name="x_iva_estimado_manual" invisible="not x_override_estimados"/>
                <field name="x_igi_estimado_manual" invisible="not x_override_estimados"/>
                <field name="x_dta_estimado_manual" invisible="not x_override_estimados"/>
                <field name="x_prv_estimado_manual" invisible="not x_override_estimados"/>
                <field name="x_total_pagado_real"/>
              </group>
              <group string="Recinto / entrega">
                <field name="x_recinto_fiscalizado"/>
                <field name="x_almacenaje"/>
                <field name="x_citas_almacen"/>
                <field name="x_transportista_entrega"
                       context="{'default_x_contact_role': 'transportista', 'default_company_type': 'company'}"/>
                <field name="x_direccion_entrega_final"/>
              </group>
            </group>

          </page>

          <page string="Mercancias / Partidas" name="mi_modulo_partidas_import"
                invisible="x_tipo_operacion != 'importacion'">
            <group>
              <field name="x_ped_factura_resumen" readonly="1"/>
            </group>
            <button name="action_open_lead_partida_factura_wizard"
                    type="object"
                    string="Asignacion masiva de factura"
                    class="btn-secondary"/>
            <field name="x_operacion_line_ids" context="{'default_lead_id': id}">
              <list editable="bottom" open_form_view="1" decoration-danger="factura_documento_error or factura_value_error">
                <field name="numero_partida"/>
                <field name="factura_documento_id"/>
                <field name="fraccion_id"/>
                <field name="quantity"/>
                <field name="value_usd"/>
              </list>
              <form string="Partida">
                <group>
                  <group string="Captura basica">
                    <field name="numero_partida"/>
                    <field name="factura_documento_id"/>
                    <field name="name"/>
                    <field name="fraccion_id"/>
                    <field name="quantity"/>
                    <field name="value_usd"/>
                    <field name="factura_validation_note" readonly="1" invisible="not factura_validation_note"/>
                  </group>
                </group>
                <group string="Comercial y mercancia">
                  <field name="sequence" invisible="1"/>
                  <field name="nico_id"/>
                  <field name="uom_id"/>
                  <field name="packages_line"/>
                  <field name="gross_weight_line"/>
                  <field name="net_weight_line"/>
                  <field name="precio_unitario"/>
                  <field name="value_mxn" readonly="1"/>
                  <field name="valor_comercial" readonly="1"/>
                  <field name="valor_aduana"/>
                </group>
                <group string="Regulatorio">
                  <field name="nom_ids" widget="many2many_tags"/>
                  <field name="permiso_ids" widget="many2many_tags"/>
                  <field name="rrna_ids" widget="many2many_tags"/>
                  <field name="labeling_required" readonly="1"/>
                  <field name="nom_compliance_status"/>
                  <field name="docs_reference"/>
                  <field name="notes_regulatorias"/>
                </group>
                <group string="Impuestos estimados">
                  <field name="igi_estimado"/>
                  <field name="iva_estimado"/>
                  <field name="dta_estimado"/>
                  <field name="prv_estimado"/>
                </group>
                <group string="Control factura">
                  <field name="factura_documento_error" readonly="1"/>
                  <field name="factura_value_error" readonly="1"/>
                </group>
              </form>
            </field>
          </page>

          <page string="Valores" name="mi_modulo_valores">
            <group>
              <group string="Resumen operativo (auto)">
                <field name="x_valor_mercancia" readonly="1"/>
                <field name="x_bultos" readonly="1"/>
                <field name="x_peso_bruto" readonly="1"/>
                <field name="x_peso_neto" readonly="1"/>
                <field name="x_volumen_cbm"/>
              </group>
              <group string="Base de valoracion aduanera">
                <field name="x_valor_factura"/>
                <field name="x_valor_aduana_estimado"/>
                <field name="x_tipo_cambio" readonly="1"/>
                <button name="action_refresh_tipo_cambio_banxico" type="object"
                        string="↻ Actualizar FIX" class="btn-link"
                        help="Consulta el tipo de cambio FIX vigente desde Banxico"/>
              </group>
            </group>
            <group>
              <group string="Incrementables">
                <field name="x_incrementable_fletes"/>
                <field name="x_incrementable_seguros"/>
                <field name="x_incrementable_embalajes"/>
                <field name="x_incrementable_otros"/>
              </group>
              <group string="Decrementables">
                <field name="x_decrementable_fletes"/>
                <field name="x_decrementable_seguros"/>
                <field name="x_decrementable_carga"/>
                <field name="x_decrementable_descarga"/>
                <field name="x_decrementable_otros"/>
              </group>
              <group string="Control financiero">
                <field name="x_cotizacion_total"/>
                <field name="x_costo_estimado"/>
              </group>
            </group>
          </page>

          <page string="Exportación" name="mi_modulo_exportacion"
                invisible="x_tipo_operacion != 'exportacion'">

            <group>
              <group string="Venta">
                <field name="x_sales_order"/>
                <field name="x_invoice_export_number"/>
                <field name="x_cliente_extranjero_name"/>
                <field name="x_direccion_destino_final"/>
                <field name="x_condiciones_venta"/>
              </group>
              <group string="Compliance">
                <field name="x_regulaciones_exportacion_ids" widget="many2many_tags"/>
                <field name="x_certificados_exportacion_ids" widget="many2many_tags"/>
                <field name="x_licencia_exportacion"/>
                <field name="x_motivo_exportacion"/>
              </group>
            </group>

            <group string="Destinatario contingencia 520">
              <field name="x_send_520_contingency"/>
              <field name="x_destinatario_520_ids" invisible="not x_send_520_contingency">
                <list editable="bottom">
                  <field name="identificacion_fiscal"/>
                  <field name="nombre"/>
                  <field name="calle"/>
                  <field name="num_interior"/>
                  <field name="num_exterior"/>
                  <field name="codigo_postal"/>
                  <field name="municipio_ciudad"/>
                  <field name="pais_id"/>
                </list>
              </field>
            </group>

            <group>
              <group string="Salida">
                <field name="x_punto_salida"/>
                <field name="x_transportista_salida"
                       domain="[('x_contact_role','=','transportista')]"
                       context="{'default_x_contact_role': 'transportista', 'default_company_type': 'company'}"/>
                <field name="x_prueba_entrega"/>
              </group>
            </group>

          </page>

          <page string="Facturación" name="mi_modulo_facturacion">
            <group>
              <group string="Cobro">
                <field name="x_factura_emitida"/>
                <field name="x_factura_ref" modifiers='{"invisible":[["x_factura_emitida","=",false]]}'/>
                <field name="x_metodo_cobro"/>
                <field name="x_pago_confirmado"/>
              </group>
              <group string="Notas internas">
                <field name="description" placeholder="Agrega observaciones relevantes de la operación..."/>
              </group>
            </group>
          </page>

          <!-- ✅ Pedimento en LEAD: SOLO RESUMEN (READ-ONLY) -->
          <page string="Pedimentos" name="mi_modulo_pedimentos_rel">
            <group>
              <group string="Acciones">
                <button name="action_crear_pedimento" type="object" string="Crear / Actualizar pedimento desde este lead" class="btn-primary"/>
              </group>
            </group>

            <field name="x_ped_operacion_ids"
                   nolabel="1"
                   context="{'default_lead_id': id}"
                   mode="list,form">

              <list>
                <button name="action_open_full_form" type="object" string="Abrir" class="btn-link"/>
                <field name="name"/>
                <field name="tipo_operacion"/>
                <field name="regimen"/>
                <field name="aduana_clave"/>
                <field name="agente_aduanal_id"/>
                <field name="patente"/>
                <field name="clave_pedimento_id"/>
                <field name="pedimento_numero"/>
                <field name="fecha_pago"/>
                <field name="fecha_liberacion"/>
                <field name="semaforo"/>
              </list>

              <form string="Pedimento">
                <sheet>
                  <div class="oe_title">
                    <h1>
                      <field name="name" placeholder="Ej. EXP-000123 / OP-00045"/>
                    </h1>
                  </div>

                  <group>
                    <group string="Resumen ejecutivo">
                      <field name="lead_id" readonly="1"/>
                      <field name="crm_factura_resumen" readonly="1"/>
                      <field name="show_advanced_info"/>
                    </group>

                    <group string="Validacion tecnica" invisible="not show_advanced_info">
                      <field name="tipo_operacion"/>
                      <field name="regimen"/>
                      <field name="incoterm"/>
                      <field name="aduana_clave"/>
                      <field name="agente_aduanal_id" domain="[('x_contact_role','=','agente_aduanal')]"/>
                      <field name="patente" readonly="1"/>
                      <field name="clave_pedimento_id"
                             domain="[('active','=',True), '|', ('tipo_operacion','=','ambas'), ('tipo_operacion','=',tipo_operacion), '|', ('regimen','=','cualquiera'), ('regimen','=',regimen)]"/>
                      <field name="layout_id" required="1"/>
                      <field name="currency_id"/>
                      <field name="pedimento_numero"/>
                      <field name="fecha_pago"/>
                      <field name="semaforo"/>
                      <field name="fecha_liberacion"/>
                      <field name="observaciones" placeholder="Notas internas del pedimento..."/>
                    </group>
                  </group>
                </sheet>
              </form>

            </field>
          </page>

        </xpath>

      </field>
    </record>

    <record id="crm_lead_partida_factura_wizard_view_form" model="ir.ui.view">
      <field name="name">crm.lead.partida.factura.wizard.form</field>
      <field name="model">crm.lead.partida.factura.wizard</field>
      <field name="arch" type="xml">
        <form string="Asignacion masiva de factura">
          <sheet>
            <group>
              <field name="lead_id" readonly="1"/>
              <field name="factura_documento_id"/>
              <field name="line_ids" widget="many2many_tags"/>
            </group>
          </sheet>
          <footer>
            <button name="action_apply" type="object" string="Aplicar" class="btn-primary"/>
            <button string="Cancelar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <record id="crm_lead_documento_view_form" model="ir.ui.view">
      <field name="name">crm.lead.documento.form</field>
      <field name="model">crm.lead.documento</field>
      <field name="arch" type="xml">
        <form string="Documento comercial" delete="0">
          <header>
            <field name="estatus" widget="statusbar"
                   statusbar_visible="pendiente,ok"
                   statusbar_onclick="1"/>
            <button name="action_archive_and_close"
                    type="object"
                    string="Eliminar documento"
                    class="btn-secondary"
                    confirm="Esta accion ocultara el documento actual del CRM. Deseas continuar?"/>
          </header>
          <sheet>
            <!-- Resumen de amparo visible de un vistazo -->
            <div class="alert alert-success mb-3"
                 invisible="has_difference or not cfdi_valor_moneda">
              <strong>✓ Totalmente amparado.</strong>
              El valor de este documento está completamente cubierto por partidas del pedimento.
            </div>
            <div class="alert alert-warning mb-3"
                 invisible="not has_difference">
              <strong>Valor pendiente de amparar:</strong>
              <field name="saldo_valor_moneda" readonly="1" nolabel="1"/> de
              <field name="cfdi_valor_moneda" readonly="1" nolabel="1"/>
              (<field name="linked_partida_count" readonly="1" nolabel="1"/> partida(s) vinculada(s)).
            </div>

            <group col="2">
              <group string="Identificacion del documento">
                <field name="tipo"/>
                <field name="folio"/>
                <field name="fecha"/>
                <field name="es_documento_principal" string="Documento principal de la remesa"/>
                <field name="archivo_file" filename="archivo_filename" string="Archivo adjunto"/>
                <field name="archivo_filename" invisible="1"/>
                <field name="notas"/>
              </group>
              <group string="Valor declarado">
                <field name="cfdi_moneda_id" string="Moneda de la factura"/>
                <field name="cfdi_valor_moneda" string="Valor en moneda original"/>
                <field name="cfdi_valor_usd" string="Equivalente USD (para SAAI)"
                       optional="hide"/>
                <field name="cfdi_termino_facturacion" string="Termino de facturacion (Incoterm)"/>
              </group>
            </group>

            <group string="Resumen de amparo" col="4">
              <field name="linked_valor_moneda" string="Amparado en partidas" readonly="1"/>
              <field name="saldo_valor_moneda" string="Pendiente por amparar" readonly="1"/>
              <field name="linked_partida_count" string="Partidas vinculadas" readonly="1"/>
            </group>

            <group string="Datos del proveedor / comprador (505)"
                   groups="modulo_aduana_odoo.group_aduana_user">
              <field name="cfdi_pais_id"/>
              <field name="cfdi_estado_id"/>
              <field name="cfdi_id_fiscal"/>
              <field name="counterparty_name_505"/>
              <field name="counterparty_street_505"/>
              <field name="counterparty_num_int_505"/>
              <field name="counterparty_num_ext_505"/>
              <field name="counterparty_zip_505"/>
              <field name="counterparty_city_505"/>
            </group>

            <group invisible="1">
              <field name="lead_id"/>
              <field name="active"/>
              <field name="has_difference"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>
