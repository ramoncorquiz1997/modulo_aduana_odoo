<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="mx_ped_consolidado_remesa_view_form" model="ir.ui.view">
      <field name="name">mx.ped.consolidado.remesa.form</field>
      <field name="model">mx.ped.consolidado.remesa</field>
      <field name="arch" type="xml">
        <form string="Remesa consolidada" delete="0">
          <header>
            <button name="action_archive_and_close"
                    type="object"
                    string="Eliminar remesa"
                    class="btn-secondary"
                    confirm="Esta accion ocultara la remesa actual de la operacion. Deseas continuar?"/>
          </header>
          <sheet>
            <group col="2">
              <group string="General">
                <field name="name" readonly="1"/>
                <field name="folio"/>
                <field name="fecha_remesa"/>
                <field name="estado"/>
                <field name="tipo_documento_fuente"/>
                <field name="cfdi_uuid" invisible="tipo_documento_fuente != 'cfdi'"/>
                <field name="numero_documento" invisible="tipo_documento_fuente == 'cfdi'"/>
              </group>
              <group string="Cruce">
                <field name="transportista_id"/>
                <field name="chofer_id"/>
                <field name="gafete_id"/>
                <field name="placas"/>
                <field name="contenedor"/>
                <field name="candados"/>
                <!-- COVE formal ligado a esta remesa -->
                <field name="cove_id"
                       domain="['|', ('operacion_id','=',operacion_id), ('operacion_id','=',False)]"
                       options="{'no_create': True}"
                       help="Selecciona el COVE de VUCEM para esta remesa. El e-document se propagará automáticamente."/>
                <field name="cove_estado" readonly="1" invisible="not cove_id"
                       widget="badge"
                       decoration-success="cove_estado == 'con_edocument'"
                       decoration-warning="cove_estado == 'enviado'"
                       decoration-muted="cove_estado == 'borrador'"/>
                <field name="acuse_valor"
                       readonly="cove_id != False"
                       help="e-Document COVE. Se llena automáticamente cuando el COVE tiene folio de VUCEM."/>
                <field name="acuse_presentacion"/>
              </group>
            </group>

            <group string="Resumen">
              <group>
                <field name="partida_count" readonly="1"/>
                <field name="total_quantity" readonly="1"/>
                <field name="total_value_usd" readonly="1"/>
              </group>
              <group>
                <field name="operacion_id" readonly="1"/>
                <field name="observaciones"/>
              </group>
            </group>

            <notebook>
              <page string="Partidas de la remesa">
                <field name="partida_rel_ids" context="{'default_remesa_id': id}">
                  <list editable="bottom">
                    <field name="partida_id"/>
                    <field name="quantity"/>
                    <field name="value_usd"/>
                    <field name="notes"/>
                  </list>
                  <form string="Partida de remesa">
                    <group>
                      <field name="partida_id" domain="[('operacion_id', '=', operacion_id)]"/>
                      <field name="quantity"/>
                      <field name="value_usd"/>
                      <field name="notes"/>
                    </group>
                    <group invisible="1">
                      <field name="sequence"/>
                      <field name="operacion_id"/>
                      <field name="remesa_id"/>
                    </group>
                  </form>
                </field>
              </page>
              <page string="Documentos de esta remesa">
                <group>
                  <div class="o_form_label">Las facturas 505 se capturan en el expediente principal. Aqui solo las asignas a esta remesa.</div>
                  <field name="factura_documento_disponible_ids" invisible="1"/>
                  <field name="factura_documento_ids"
                         widget="many2many_tags"
                         domain="[('id', 'in', factura_documento_disponible_ids)]"
                         options="{'no_create': True, 'no_create_edit': True}"/>
                </group>
                <group>
                  <div class="o_form_label">Documentos actualmente ligados a esta remesa.</div>
                </group>
                <field name="documento_ids">
                  <list>
                    <field name="tipo"/>
                    <field name="folio"/>
                    <field name="fecha"/>
                    <field name="es_documento_principal"/>
                    <field name="aplica_partida_especifica"/>
                    <field name="partida_id" optional="hide"/>
                    <field name="estatus"/>
                    <button name="action_open_full_form" type="object" string="Abrir" class="btn-link"/>
                  </list>
                </field>
              </page>
            </notebook>

            <group invisible="1">
              <field name="active"/>
              <field name="company_id"/>
              <field name="attachment_id"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="mx_ped_documento_remesa_view_form" model="ir.ui.view">
      <field name="name">mx.ped.documento.remesa.form</field>
      <field name="model">mx.ped.documento</field>
      <field name="arch" type="xml">
        <form string="Documento de remesa">
          <sheet>
            <field name="show_advanced_info" invisible="1"/>
            <group col="2">
              <group string="Datos del documento">
                <field name="tipo"/>
                <field name="folio"/>
                <field name="fecha"/>
                <field name="es_documento_principal"/>
                <field name="archivo_file" filename="archivo_filename"/>
                <field name="archivo_filename" invisible="1"/>
                <field name="estatus"/>
                <field name="notas"/>
              </group>
              <group string="Relacion con mercancia">
                <div class="o_form_label">Sube aqui el archivo del documento. Marca "Documento principal" para la relacion de facturas o el documento que acompana fisicamente la remesa.</div>
                <field name="aplica_partida_especifica"/>
                <field name="partida_id"
                       invisible="not aplica_partida_especifica"
                       domain="[('operacion_id', '=', operacion_id)]"/>
              </group>
            </group>
            <group string="Snapshot 505" class="mx-advanced-panel" invisible="not show_advanced_info">
              <group>
                <field name="cfdi_termino_facturacion"/>
                <field name="cfdi_moneda_id"/>
                <field name="cfdi_valor_usd"/>
                <field name="cfdi_valor_moneda"/>
                <field name="cfdi_pais_id"/>
                <field name="cfdi_estado_id"/>
                <field name="cfdi_id_fiscal"/>
              </group>
              <group>
                <field name="counterparty_name_505"/>
                <field name="counterparty_street_505"/>
                <field name="counterparty_num_int_505"/>
                <field name="counterparty_num_ext_505"/>
                <field name="counterparty_zip_505"/>
                <field name="counterparty_city_505"/>
              </group>
            </group>
            <group invisible="1">
              <field name="company_id"/>
              <field name="company_currency_id"/>
              <field name="operacion_id"/>
              <field name="remesa_id"/>
              <field name="registro_codigo"/>
              <field name="forma_pago_id"/>
              <field name="forma_pago_code"/>
              <field name="attachment_id"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>
