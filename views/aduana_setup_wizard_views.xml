<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="aduana_setup_wizard_view_form" model="ir.ui.view">
      <field name="name">aduana.setup.wizard.form</field>
      <field name="model">aduana.setup.wizard</field>
      <field name="arch" type="xml">
        <form string="Configuración inicial Aduanex">
          <sheet>
            <!-- Indicador de paso -->
            <div class="o_statusbar_status d-flex justify-content-center mb-3">
              <span class="o_status_label me-2 fw-bold">
                Paso <field name="step_number" readonly="1"/> de 4:
              </span>
              <field name="step" widget="statusbar"
                     statusbar_visible="agencia,vucem,catalogo,listo"
                     readonly="1"/>
            </div>

            <!-- Paso 1: Agencia -->
            <group invisible="step != 'agencia'" string="Datos de la agencia">
              <group string="Agente existente">
                <field name="agente_id"
                       placeholder="Busca un contacto con rol Agente Aduanal…"/>
              </group>
              <group string="O crea uno nuevo">
                <field name="agente_nombre"
                       placeholder="Razón social"
                       invisible="agente_id"/>
                <field name="agente_rfc"
                       placeholder="RFC"
                       invisible="agente_id"/>
                <field name="patente"
                       placeholder="4 dígitos"/>
                <field name="num_autorizacion"
                       placeholder="Número de autorización"/>
              </group>
            </group>

            <!-- Paso 2: VUCEM -->
            <group invisible="step != 'vucem'" string="Credencial VUCEM">
              <field name="vucem_ambiente"/>
              <field name="vucem_cert_file" filename="vucem_cert_filename" widget="binary"/>
              <field name="vucem_cert_filename" invisible="1"/>
              <field name="vucem_key_file" filename="vucem_key_filename" widget="binary"/>
              <field name="vucem_key_filename" invisible="1"/>
              <field name="vucem_key_password" password="True"/>
              <div class="alert alert-info" role="alert">
                Si no tienes la credencial VUCEM aún, puedes omitir este paso y configurarla
                más tarde en <b>Operaciones &gt; Credenciales WS</b>.
              </div>
            </group>

            <!-- Paso 3: Catálogos -->
            <group invisible="step != 'catalogo'" string="Aduanas/Secciones">
              <field name="aduana_seccion_ids" widget="many2many_tags"
                     placeholder="Selecciona las aduanas donde opera tu agencia…"/>
              <div class="alert alert-info" role="alert">
                Puedes agregar más aduanas en cualquier momento desde
                <b>Catálogos &gt; Aduanas y Secciones</b>.
              </div>
            </group>

            <!-- Paso 4: Listo -->
            <div invisible="step != 'listo'" class="text-center py-4">
              <i class="fa fa-check-circle fa-4x text-success mb-3"/>
              <h3>¡Aduanex está configurado!</h3>
              <p class="text-muted">
                Tu agencia ya puede crear expedientes desde
                <b>CRM &gt; Pipeline</b>.
              </p>
            </div>
          </sheet>

          <footer>
            <button name="action_prev" type="object"
                    string="Anterior"
                    invisible="step == 'agencia'"
                    class="btn-secondary"/>
            <button name="action_next" type="object"
                    string="Siguiente"
                    invisible="step == 'listo'"
                    class="btn-primary"/>
            <button name="action_finish" type="object"
                    string="Finalizar"
                    invisible="step != 'listo'"
                    class="btn-success"/>
            <button special="cancel" string="Cerrar" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Acción para abrir el wizard -->
    <record id="action_aduana_setup_wizard" model="ir.actions.act_window">
      <field name="name">Configuracion inicial Aduanex</field>
      <field name="res_model">aduana.setup.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>

    <!-- Menú de acceso rápido desde Configuración -->
    <menuitem id="menu_aduana_setup_wizard"
              name="Configuracion inicial"
              parent="mx_ped_operacion_menu_root"
              action="action_aduana_setup_wizard"
              sequence="99"
              groups="base.group_system"/>

  </data>
</odoo>
