<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="mx_ped_desistimiento_wizard_view_form" model="ir.ui.view">
      <field name="name">mx.ped.desistimiento.wizard.form</field>
      <field name="model">mx.ped.desistimiento.wizard</field>
      <field name="arch" type="xml">
        <form string="Generar Eliminación / Desistimiento">
          <sheet>

            <!-- ── Banner informativo ───────────────────────────────────────── -->
            <div class="alert alert-info mb-3">
              <i class="fa fa-info-circle me-2"/>
              <strong>¿Cuál aplica en tu caso?</strong><br/>
              <ul class="mb-0 mt-1">
                <li>
                  <strong>Eliminación (mov. 2)</strong> — El pedimento fue
                  validado por el SAAI pero <em>aún no fue pagado</em>.
                  Se usa para cancelar antes del pago.
                </li>
                <li>
                  <strong>Desistimiento (mov. 3)</strong> — El pedimento fue
                  validado <em>y pagado</em>, pero la mercancía no llegó a
                  entrar o salir del país. Se solicita devolución de impuestos.
                </li>
              </ul>
            </div>

            <!-- ── Datos del pedimento original (readonly) ──────────────────── -->
            <group string="Pedimento original que se cancela" col="4">
              <field name="operacion_id" readonly="1" colspan="4"/>
              <field name="orig_pedimento_numero" readonly="1"/>
              <field name="orig_clave_pedimento"  readonly="1"/>
              <field name="orig_patente"           readonly="1"/>
              <field name="orig_aduana"            readonly="1"/>
              <field name="orig_tipo_operacion"    readonly="1"/>
              <field name="orig_fecha_operacion"   readonly="1"/>
              <field name="orig_fecha_pago"        readonly="1"/>
              <field name="orig_acuse_validacion"  readonly="1"
                     decoration-danger="not orig_acuse_validacion"/>
            </group>

            <!-- Advertencia si el pedimento original no tiene acuse -->
            <div class="alert alert-danger mb-3" invisible="orig_acuse_validacion">
              <i class="fa fa-exclamation-circle me-2"/>
              <strong>El pedimento original no tiene acuse de validación registrado.</strong>
              El acuse es obligatorio para generar una eliminación o desistimiento.
              Cierra este wizard, abre el pedimento original, llena el campo
              <strong>"Acuse electrónico validación"</strong> (en el grupo Aduana y Agente)
              con el código de 8 dígitos que entregó el SAAI al validarlo, guarda y vuelve a intentarlo.
            </div>

            <!-- ── Datos del nuevo pedimento ────────────────────────────────── -->
            <group string="Datos del nuevo pedimento de cancelación" col="4">
              <field name="tipo_movimiento"
                     widget="radio"
                     colspan="4"/>
              <field name="nueva_fecha_operacion"/>
              <field name="nuevo_acuse_validacion"
                     placeholder="00000000"
                     help="Se toma automáticamente del pedimento original. Modifícalo solo si el acuse del desistimiento/eliminación es diferente al del pedimento original."/>
            </group>

            <group string="Motivo de cancelación (registro 800)" col="1">
              <field name="motivo"
                     nolabel="1"
                     placeholder="Describe el motivo de la eliminación o desistimiento. Este texto se transmite en el registro 800 del archivo TXT al SAAI."
                     colspan="1"/>
            </group>

            <!-- ── Advertencia final ─────────────────────────────────────────── -->
            <div class="alert alert-warning mb-0">
              <i class="fa fa-exclamation-triangle me-2"/>
              <strong>Flujo de trabajo:</strong>
              Al confirmar se crea el nuevo pedimento (registros 500, 800 y 801).
              El pedimento original <em>no se modifica</em>.
              <br/>
              Si aún no tienes el acuse, créalo sin él → exporta el TXT →
              preséntalo al SAAI → cuando el SAAI te devuelva el acuse,
              ve al nuevo pedimento, tab <strong>"Cancelación / Desistimiento (800)"</strong>
              → campo <strong>"Acuse de validación"</strong>, llénalo y vuelve a exportar.
            </div>

          </sheet>
          <footer>
            <button name="action_crear_desistimiento"
                    type="object"
                    string="Crear pedimento de cancelación"
                    class="btn-primary"
                    data-hotkey="v"/>
            <button string="Cancelar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Acción para abrir el wizard desde la operación -->
    <record id="action_mx_ped_desistimiento_wizard" model="ir.actions.act_window">
      <field name="name">Generar Eliminación / Desistimiento</field>
      <field name="res_model">mx.ped.desistimiento.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="context">{'default_operacion_id': active_id}</field>
    </record>

  </data>
</odoo>
