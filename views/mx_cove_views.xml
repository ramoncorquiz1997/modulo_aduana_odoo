<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ══════════════════════════════════════════════════════════════════════
         SECUENCIA
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="seq_mx_cove" model="ir.sequence">
      <field name="name">COVE</field>
      <field name="code">mx.cove</field>
      <field name="prefix">COVE/%(year)s/</field>
      <field name="padding">4</field>
      <field name="company_id" eval="False"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         VISTA LISTA — mx.cove
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_mx_cove_list" model="ir.ui.view">
      <field name="name">mx.cove.list</field>
      <field name="model">mx.cove</field>
      <field name="arch" type="xml">
        <list string="COVEs" decoration-info="estado == 'borrador'"
              decoration-success="estado == 'con_edocument'"
              decoration-warning="estado == 'enviado'"
              decoration-danger="estado == 'rechazado'">
          <field name="name"/>
          <field name="tipo_operacion"/>
          <field name="numero_factura_original"/>
          <field name="fecha_expedicion"/>
          <field name="emisor_nombre"/>
          <field name="dest_nombre"/>
          <field name="estado" widget="badge"
                 decoration-info="estado == 'borrador'"
                 decoration-warning="estado == 'enviado'"
                 decoration-success="estado == 'con_edocument'"
                 decoration-danger="estado == 'rechazado'"/>
          <field name="e_document"/>
          <field name="log_count" string="Logs"/>
        </list>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         VISTA FORM — mx.cove
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_mx_cove_form" model="ir.ui.view">
      <field name="name">mx.cove.form</field>
      <field name="model">mx.cove</field>
      <field name="arch" type="xml">
        <form string="Comprobante de Valor Electrónico (COVE)">

          <!-- Barra de estado -->
          <header>
            <button name="action_transmitir_cove"
                    type="object"
                    string="Transmitir a VUCEM"
                    class="btn-primary"
                    invisible="estado not in ('borrador', 'rechazado')"
                    confirm="¿Confirmas que los datos son correctos y deseas transmitir este COVE a VUCEM?"/>
            <button name="action_consultar_resultado"
                    type="object"
                    string="Consultar resultado"
                    invisible="estado != 'enviado' or not numero_operacion_vucem"/>
            <button name="action_ver_logs"
                    type="object"
                    string="Ver logs VUCEM"
                    class="btn-secondary"/>
            <field name="estado" widget="statusbar"
                   statusbar_visible="borrador,enviado,con_edocument"/>
          </header>

          <sheet>
            <div class="oe_button_box" name="button_box">
              <button name="action_ver_logs" type="object" class="oe_stat_button" icon="fa-list">
                <field name="log_count" widget="statinfo" string="Logs"/>
              </button>
            </div>

            <div class="oe_title">
              <h1><field name="name" readonly="1"/></h1>
            </div>

            <!-- ── Resultado VUCEM ─────────────────────────────────────── -->
            <div class="alert alert-success mb-3" invisible="not e_document">
              <i class="fa fa-check-circle me-2"/>
              <strong>e-Document asignado:</strong>
              <field name="e_document" readonly="1" class="ms-2"/>
              — Vigencia: 90 días desde la transmisión.
            </div>
            <div class="alert alert-warning mb-3"
                 invisible="estado != 'enviado' or not numero_operacion_vucem">
              <i class="fa fa-clock-o me-2"/>
              Transmitido. Núm. operación: <strong><field name="numero_operacion_vucem" readonly="1"/></strong>
              — Usa <em>Consultar resultado</em> para obtener el e-document.
            </div>

            <!-- ── Configuración ──────────────────────────────────────── -->
            <group string="Configuración" col="4">
              <field name="credencial_id"/>
              <field name="operacion_id"/>
              <field name="company_id" groups="base.group_multi_company"/>
              <field name="e_document_adenda"
                     help="Solo si este COVE es adenda de uno existente."/>
            </group>

            <!-- ── Tabs principales ───────────────────────────────────── -->
            <notebook>

              <!-- TAB 1: Comprobante -->
              <page string="Comprobante" name="comprobante">
                <group col="4">
                  <field name="tipo_operacion" required="1"/>
                  <field name="tipo_figura" required="1"/>
                  <field name="fecha_expedicion" required="1"/>
                  <field name="correo_electronico" required="1"/>
                </group>
                <group string="Factura" col="4">
                  <field name="numero_factura_original" required="1"/>
                  <field name="certificado_origen" required="1"/>
                  <field name="subdivision" required="1"/>
                  <field name="numero_exportador_autorizado"/>
                </group>
                <group string="Patentes aduanales y RFCs de consulta" col="2">
                  <field name="patente_aduanal_ids" nolabel="1" colspan="1">
                    <list editable="bottom">
                      <field name="patente" placeholder="0000"/>
                    </list>
                  </field>
                  <field name="rfc_consulta_ids" nolabel="1" colspan="1">
                    <list editable="bottom">
                      <field name="rfc" placeholder="RFC consulta adicional"/>
                    </list>
                  </field>
                </group>
                <group string="Observaciones">
                  <field name="observaciones" nolabel="1" colspan="2"
                         placeholder="Observaciones, leyendas de TLC, etc. (máx. 300 chars)"/>
                </group>
              </page>

              <!-- TAB 2: Emisor -->
              <page string="Emisor (proveedor)" name="emisor">
                <group string="Identificación" col="4">
                  <field name="emisor_tipo_identificador" required="1"/>
                  <field name="emisor_identificacion" required="1"/>
                  <field name="emisor_nombre" required="1"/>
                  <div/>
                  <field name="emisor_apellido_paterno"/>
                  <field name="emisor_apellido_materno"/>
                </group>
                <group string="Domicilio" col="4">
                  <field name="emisor_calle" required="1"/>
                  <field name="emisor_numero_exterior"/>
                  <field name="emisor_numero_interior"/>
                  <field name="emisor_colonia"/>
                  <field name="emisor_localidad"/>
                  <field name="emisor_municipio"/>
                  <field name="emisor_entidad_federativa"/>
                  <field name="emisor_pais" required="1" placeholder="MEX, USA, CHN…"/>
                  <field name="emisor_codigo_postal"/>
                </group>
              </page>

              <!-- TAB 3: Destinatario -->
              <page string="Destinatario (importador)" name="destinatario">
                <group string="Identificación" col="4">
                  <field name="dest_tipo_identificador" required="1"/>
                  <field name="dest_identificacion" required="1"/>
                  <field name="dest_nombre" required="1"/>
                  <div/>
                  <field name="dest_apellido_paterno"/>
                  <field name="dest_apellido_materno"/>
                </group>
                <group string="Domicilio" col="4">
                  <field name="dest_calle" required="1"/>
                  <field name="dest_numero_exterior"/>
                  <field name="dest_numero_interior"/>
                  <field name="dest_colonia"/>
                  <field name="dest_localidad"/>
                  <field name="dest_municipio"/>
                  <field name="dest_entidad_federativa"/>
                  <field name="dest_pais" required="1" placeholder="MEX, USA, CHN…"/>
                  <field name="dest_codigo_postal"/>
                </group>
              </page>

              <!-- TAB 4: Mercancías -->
              <page string="Mercancías" name="mercancias">
                <field name="mercancia_ids" nolabel="1">
                  <list editable="bottom" optional="show">
                    <field name="sequence" widget="handle"/>
                    <field name="descripcion_generica"/>
                    <field name="clave_unidad_medida"/>
                    <field name="tipo_moneda"/>
                    <field name="cantidad" digits="[15,3]"/>
                    <field name="valor_unitario" digits="[23,6]"/>
                    <field name="valor_total" digits="[23,6]"/>
                    <field name="valor_dolares" digits="[16,4]"/>
                    <field name="marca" optional="hide"/>
                    <field name="modelo" optional="hide"/>
                    <field name="sub_modelo" optional="hide"/>
                    <field name="numero_serie" optional="hide"/>
                  </list>
                </field>
              </page>

              <!-- TAB 5: Resultado VUCEM -->
              <page string="Resultado VUCEM" name="resultado"
                    invisible="estado == 'borrador'">
                <group col="2">
                  <field name="numero_operacion_vucem" readonly="1"/>
                  <field name="e_document" readonly="1"/>
                  <field name="acuse_hora_recepcion" readonly="1"/>
                </group>
                <group string="Mensaje VUCEM">
                  <field name="acuse_mensaje" nolabel="1" readonly="1" colspan="2"/>
                </group>
              </page>

              <!-- TAB 6: Logs -->
              <page string="Logs VUCEM" name="logs">
                <field name="log_ids" nolabel="1" readonly="1">
                  <list decoration-danger="estatus not in ('exitoso')"
                        decoration-success="estatus == 'exitoso'">
                    <field name="timestamp"/>
                    <field name="tipo_operacion"/>
                    <field name="ambiente"/>
                    <field name="estatus" widget="badge"
                           decoration-success="estatus == 'exitoso'"
                           decoration-danger="estatus != 'exitoso'"/>
                    <field name="numero_operacion"/>
                    <field name="e_document"/>
                    <field name="duracion_ms"/>
                    <field name="error_code"/>
                  </list>
                </field>
              </page>

            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         VISTA FORM — mx.vucem.log (detalle)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_mx_vucem_log_form" model="ir.ui.view">
      <field name="name">mx.vucem.log.form</field>
      <field name="model">mx.vucem.log</field>
      <field name="arch" type="xml">
        <form string="Log VUCEM" create="false" edit="false">
          <sheet>
            <group col="4">
              <field name="timestamp"/>
              <field name="tipo_operacion"/>
              <field name="ambiente"/>
              <field name="estatus"/>
              <field name="numero_operacion"/>
              <field name="e_document"/>
              <field name="duracion_ms"/>
              <field name="credencial_id"/>
            </group>
            <group string="Error">
              <field name="error_code"/>
              <field name="error_descripcion" nolabel="1" colspan="2"/>
            </group>
            <group string="Cadena original">
              <field name="cadena_original" nolabel="1" colspan="2" readonly="1"
                     widget="text"/>
            </group>
            <group string="XML enviado">
              <field name="xml_enviado" nolabel="1" colspan="2" readonly="1"
                     widget="text"/>
            </group>
            <group string="Respuesta recibida">
              <field name="xml_recibido" nolabel="1" colspan="2" readonly="1"
                     widget="text"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         ACCIONES
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_mx_cove" model="ir.actions.act_window">
      <field name="name">COVEs</field>
      <field name="res_model">mx.cove</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea tu primer Comprobante de Valor Electrónico
        </p>
        <p>
          El COVE es el documento electrónico que comprueba el valor de
          las mercancías ante la Ventanilla Única (VUCEM).
        </p>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         MENÚ
    ═══════════════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_mx_cove_root"
              name="COVE / VUCEM"
              parent="modulo_aduana_odoo.menu_aduana_root"
              sequence="35"/>

    <menuitem id="menu_mx_cove_list"
              name="Comprobantes de Valor (COVE)"
              parent="menu_mx_cove_root"
              action="action_mx_cove"
              sequence="10"/>

  </data>
</odoo>
