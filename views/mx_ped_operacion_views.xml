<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- LIST (Odoo 18) -->
    <record id="mx_ped_operacion_view_list" model="ir.ui.view">
      <field name="name">mx.ped.operacion.list</field>
      <field name="model">mx.ped.operacion</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="lead_id"/>
          <field name="tipo_operacion"/>
          <field name="regimen"/>
          <field name="aduana_clave"/>
          <field name="patente"/>
          <field name="clave_pedimento_id"/>
          <field name="pedimento_numero"/>
          <field name="fecha_pago"/>
          <field name="semaforo"/>
        </list>
      </field>
    </record>

    <!-- FORM -->
    <record id="mx_ped_operacion_view_form" model="ir.ui.view">
      <field name="name">mx.ped.operacion.form</field>
      <field name="model">mx.ped.operacion</field>
      <field name="arch" type="xml">
        <form string="Pedimento">
          <header>
            <button name="action_asignar_numero_pedimento" type="object" string="Asignar N\u00fam. Pedimento" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_pedimento_core"/>
            <button name="action_preparar_estructura" type="object" string="Preparar estructura" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_pedimento_core"/>
            <button name="action_simular_estructura" type="object" string="Simular estructura" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_pedimento_core"/>
            <button name="action_generar_contribuciones_557" type="object" string="Generar contribuciones 557" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_pedimento_core"/>
            <button name="action_export_txt" type="object" string="Exportar TXT" class="btn-primary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_export_txt"/>
            <button name="action_avc_generar" type="object" string="Generar AVC" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_avc_generar"/>
            <button name="action_avc_consultar" type="object" string="Consultar AVC" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_avc_consultar"/>
            <button name="action_avc_eliminar" type="object" string="Eliminar AVC" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_avc_eliminar"/>
            <button name="action_cargar_desde_lead" type="object" string="Cargar desde Lead" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_cargar_lead"/>
            <button name="action_crear_factura" type="object" string="Crear factura" class="btn-secondary" groups="base.group_system,modulo_aduana_odoo.group_aduana_btn_crear_factura"/>
          </header>
          <sheet>
            <div class="oe_button_box" name="button_box">
              <button type="object" name="action_view_facturas" class="oe_stat_button" icon="fa-file-text-o">
                <field name="invoice_count" widget="statinfo" string="Facturas"/>
              </button>
            </div>
            <div class="oe_title">
              <h1><field name="name"/></h1>
            </div>

            <group col="2">
              <group string="Operación">
                <field name="show_acuse_ui" invisible="1"/>
                <field name="show_formas_pago_ui" invisible="1"/>
                <field name="lead_id"/>
                <field name="tipo_operacion"/>
                <field name="tipo_movimiento"/>
                <field name="es_rectificacion" invisible="tipo_movimiento != '1'"/>
                <field name="formas_pago_claves" invisible="not show_formas_pago_ui"/>
                <field name="regimen"/>
                <field name="incoterm"/>
                <field name="fecha_operacion"/>
                <field name="clave_pedimento_id"
                       domain="[('active','=',True), '|', ('tipo_operacion','=','ambas'), ('tipo_operacion','=',tipo_operacion), '|', ('regimen','=','cualquiera'), ('regimen','=',regimen)]"/>
                <field name="layout_id" required="1"/>
                <field name="currency_id"/>
                <field name="show_advanced"/>
              </group>
              <group string="Aduana y Agente">
                <field name="aduana_seccion_despacho_id"/>
                <field name="aduana_clave"/>
                <field name="aduana_seccion_entrada_salida_id"/>
                <field name="agente_aduanal_id" domain="[('x_contact_role','=','agente_aduanal')]"/>
                <field name="patente" readonly="1"/>
                <field name="curp_agente"/>
                <field name="acuse_validacion" invisible="not show_acuse_ui"/>
                <field name="company_id" invisible="1"/>
                <field name="ws_ambiente"/>
                <field name="ws_credencial_id"/>
                <field name="avc_modalidad_cruce_id"/>
                <field name="avc_tipo_documento_id"/>
                <field name="avc_transportista_id"
                       context="{'default_x_contact_role': 'transportista', 'default_company_type': 'company'}"/>
                <field name="avc_chofer_id"
                       context="{'default_x_contact_role': 'chofer', 'default_parent_id': avc_transportista_id, 'default_function': 'Chofer', 'default_company_type': 'person'}"/>
                <field name="avc_gafete_id"/>
                <field name="avc_tag" invisible="avc_modalidad_cruce_id != '1'"/>
                <field name="avc_numero_gafete" invisible="avc_modalidad_cruce_id != '2'"/>
                <field name="avc_fast_id"/>
                <field name="avc_datos_adicionales"/>
              </group>
            </group>

            <group col="2">
              <group string="Participantes">
                <field name="cliente_id" readonly="1"/>
                <field name="importador_id" readonly="1"/>
                <field name="exportador_id" readonly="1"/>
                <field name="proveedor_id" readonly="1"/>
                <field name="participante_id" readonly="1"/>
                <field name="participante_rfc" readonly="1"/>
                <field name="participante_curp" readonly="1"/>
              </group>
              <group string="Resultado">
                <field name="pedimento_numero"/>
                <field name="fecha_pago"/>
                <field name="semaforo"/>
                <field name="fecha_liberacion"/>
                <field name="observaciones"/>
                <field name="avc_numero" readonly="1"/>
                <field name="avc_estatus" readonly="1"/>
              </group>
            </group>
            <group col="2" string="Resumen fiscal automático">
              <group>
                <field name="partida_count" readonly="1"/>
                <field name="total_packages_line" readonly="1"/>
                <field name="total_gross_weight" readonly="1"/>
                <field name="total_net_weight" readonly="1"/>
                <field name="total_value_usd" readonly="1"/>
                <field name="total_value_mxn" readonly="1"/>
              </group>
              <group>
                <field name="total_igi_estimado" readonly="1"/>
                <field name="total_iva_estimado" readonly="1"/>
                <field name="total_dta_estimado" readonly="1"/>
                <field name="total_prv_estimado" readonly="1"/>
                <field name="total_impuestos_estimados" readonly="1"/>
              </group>
            </group>

            <notebook>
              <page string="Partidas">
                <field name="partida_ids" context="{'default_operacion_id': id}">
                  <list editable="bottom">
                    <field name="numero_partida"/>
                    <field name="fraccion_id"/>
                    <field name="nico_id"/>
                    <field name="quantity"/>
                    <field name="uom_id"/>
                    <field name="packages_line"/>
                    <field name="gross_weight_line"/>
                    <field name="net_weight_line"/>
                    <field name="value_usd"/>
                    <field name="precio_unitario"/>
                    <field name="value_mxn" readonly="1"/>
                    <field name="descripcion"/>
                    <field name="unidad_tarifa"/>
                    <field name="cantidad_tarifa"/>
                    <field name="valor_aduana"/>
                    <field name="igi_rate" readonly="1"/>
                    <field name="iva_rate" readonly="1"/>
                    <field name="nom_ids" widget="many2many_tags"/>
                    <field name="permiso_ids" widget="many2many_tags"/>
                    <field name="rrna_ids" widget="many2many_tags"/>
                    <field name="labeling_required" readonly="1"/>
                    <field name="nom_compliance_status"/>
                    <field name="docs_reference"/>
                    <field name="notes_regulatorias"/>
                    <field name="forma_pago_sugerida_id"/>
                    <field name="igi_estimado"/>
                    <field name="iva_estimado"/>
                    <field name="dta_estimado"/>
                    <field name="prv_estimado"/>
                  </list>
                  <form string="Partida pedimento">
                    <group>
                      <group string="Mercancia">
                        <field name="numero_partida"/>
                        <field name="fraccion_id"/>
                        <field name="nico_id"/>
                        <field name="descripcion"/>
                      </group>
                      <group string="Cantidades y valor">
                        <field name="quantity"/>
                        <field name="uom_id"/>
                        <field name="packages_line"/>
                        <field name="gross_weight_line"/>
                        <field name="net_weight_line"/>
                        <field name="value_usd"/>
                        <field name="precio_unitario"/>
                        <field name="value_mxn" readonly="1"/>
                      </group>
                    </group>
                    <group string="Regulatorio">
                      <field name="nom_ids" widget="many2many_tags"/>
                      <field name="permiso_ids" widget="many2many_tags"/>
                      <field name="rrna_ids" widget="many2many_tags"/>
                      <field name="labeling_required" readonly="1"/>
                      <field name="nom_compliance_status"/>
                      <field name="docs_reference"/>
                      <field name="notes_regulatorias"/>
                      <field name="forma_pago_sugerida_id"/>
                    </group>
                    <group string="Impuestos estimados">
                      <field name="igi_rate" readonly="1"/>
                      <field name="iva_rate" readonly="1"/>
                      <field name="igi_estimado"/>
                      <field name="iva_estimado"/>
                      <field name="dta_estimado"/>
                      <field name="prv_estimado"/>
                    </group>
                  </form>
                </field>
              </page>
              <page string="Contribuciones 510" invisible="not show_advanced">
                <field name="contribucion_global_ids" context="{'default_operacion_id': id}">
                  <list editable="bottom">
                    <field name="tipo_contribucion"/>
                    <field name="tasa"/>
                    <field name="base"/>
                    <field name="importe"/>
                    <field name="forma_pago_id"/>
                    <field name="forma_pago_code" readonly="1"/>
                  </list>
                </field>
              </page>
              <page string="Contribuciones 557" invisible="not show_advanced">
                <field name="partida_contribucion_ids" context="{'default_operacion_id': id}">
                  <list editable="bottom">
                    <field name="partida_id"/>
                    <field name="tipo_contribucion"/>
                    <field name="tasa"/>
                    <field name="base"/>
                    <field name="importe"/>
                    <field name="forma_pago_id"/>
                    <field name="forma_pago_code" readonly="1"/>
                  </list>
                </field>
              </page>
              <page string="Docs virtuales 514" invisible="not show_advanced">
                <field name="documento_ids" context="{'default_operacion_id': id, 'default_registro_codigo': '514'}">
                  <list editable="bottom">
                    <field name="registro_codigo"/>
                    <field name="tipo"/>
                    <field name="folio"/>
                    <field name="partida_id"/>
                    <field name="forma_pago_id"/>
                    <field name="forma_pago_code" readonly="1"/>
                    <field name="fecha"/>
                    <field name="estatus"/>
                  </list>
                </field>
              </page>
              <page string="Identificadores">
                <group string="Identificadores de operación">
                  <field name="identificador_pedimento_ids" context="{'default_operacion_id': id}">
                    <list editable="bottom">
                      <field name="sequence" optional="hide"/>
                      <field name="identificador_id"/>
                      <field name="code" readonly="1"/>
                      <field name="complemento1"/>
                      <field name="complemento2"/>
                      <field name="complemento3"/>
                      <field name="notes"/>
                    </list>
                    <form string="Identificador de operación">
                      <group>
                        <field name="sequence"/>
                        <field name="identificador_id"/>
                        <field name="code" readonly="1"/>
                        <field name="complemento1"/>
                        <field name="complemento2"/>
                        <field name="complemento3"/>
                        <field name="notes"/>
                      </group>
                    </form>
                  </field>
                </group>
              </page>
              <page string="Cuenta aduanera">
                <group string="Lineas de cuenta aduanera">
                  <field name="cuenta_aduanera_ids" context="{'default_operacion_id': id}">
                    <list editable="bottom">
                      <field name="sequence" optional="hide"/>
                      <field name="institucion_financiera_id"/>
                      <field name="numero_contrato"/>
                      <field name="folio_constancia"/>
                      <field name="fecha_constancia"/>
                      <field name="tipo_cuenta"/>
                      <field name="tipo_garantia_id"/>
                      <field name="valor_unitario_titulo"/>
                      <field name="total_garantia"/>
                      <field name="cantidad_um"/>
                      <field name="titulos_asignados"/>
                      <field name="notes"/>
                    </list>
                    <form string="Cuenta aduanera">
                      <group>
                        <field name="sequence"/>
                        <field name="institucion_financiera_id"/>
                        <field name="numero_contrato"/>
                        <field name="folio_constancia"/>
                        <field name="fecha_constancia"/>
                        <field name="tipo_cuenta"/>
                        <field name="tipo_garantia_id"/>
                        <field name="valor_unitario_titulo"/>
                        <field name="total_garantia"/>
                        <field name="cantidad_um"/>
                        <field name="titulos_asignados"/>
                        <field name="notes"/>
                      </group>
                    </form>
                  </field>
                </group>
              </page>
              <page string="Registros">
                <field name="registro_ids">
                  <list editable="bottom">
                    <field name="codigo"/>
                    <field name="secuencia"/>
                    <field name="valores"/>
                  </list>
                </field>
              </page>
              <page string="AVC">
                <group>
                  <group>
                    <field name="avc_numero" readonly="1"/>
                    <field name="avc_estatus" readonly="1"/>
                    <field name="avc_fecha_emision" readonly="1"/>
                    <field name="avc_fecha_vigencia" readonly="1"/>
                    <field name="avc_url_detail" readonly="1"/>
                    <field name="avc_last_sync" readonly="1"/>
                    <field name="avc_transportista_id" readonly="1"/>
                    <field name="avc_chofer_id" readonly="1"/>
                    <field name="avc_gafete_id" readonly="1"/>
                  </group>
                  <group>
                    <field name="avc_sync_error" readonly="1"/>
                    <field name="avc_folio_validacion" readonly="1"/>
                    <field name="avc_validacion_agencia" readonly="1"/>
                    <field name="avc_peticion_json" readonly="1"/>
                  </group>
                </group>
              </page>
              <page string="Trazabilidad reglas">
                <group>
                  <field name="estructura_escenario" readonly="1"/>
                  <field name="rulepack_id" readonly="1" options="{'no_create': True}"/>
                  <field name="estructura_regla_id" readonly="1"/>
                  <field name="rule_trace_at" readonly="1"/>
                  <field name="rule_trace_json" readonly="1"/>
                </group>
              </page>
              <page string="Configuracion tecnica">
                <group>
                  <group>
                    <field name="strict_mode_policy"/>
                    <field name="strict_mode_effective" readonly="1"/>
                  </group>
                  <group>
                    <field name="rulepack_id" options="{'no_create': True}"/>
                    <field name="estructura_regla_id" options="{'no_create': True}"/>
                  </group>
                </group>
              </page>
            </notebook>

          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <!-- ACTION -->
    <record id="mx_ped_operacion_action" model="ir.actions.act_window">
      <field name="name">Pedimentos</field>
      <field name="res_model">mx.ped.operacion</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- MENÃš (opcional) -->
    <menuitem id="mx_ped_operacion_menu_root" name="Aduana" sequence="90"/>
    <menuitem id="mx_ped_operacion_menu"
              name="Pedimentos"
              parent="mx_ped_operacion_menu_root"
              action="mx_ped_operacion_action"
              sequence="10"/>

  </data>
</odoo>
