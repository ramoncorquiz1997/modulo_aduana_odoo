<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="mx_ped_partida_factura_wizard_view_form" model="ir.ui.view">
      <field name="name">mx.ped.partida.factura.wizard.form</field>
      <field name="model">mx.ped.partida.factura.wizard</field>
      <field name="arch" type="xml">
        <form string="Asignacion masiva de factura">
          <sheet>
            <group>
              <field name="operacion_id" readonly="1"/>
              <field name="factura_documento_id"/>
              <field name="partida_ids" widget="many2many_tags"/>
            </group>
          </sheet>
          <footer>
            <button name="action_apply" type="object" string="Aplicar" class="btn-primary"/>
            <button string="Cancelar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>
  </data>
</odoo>
