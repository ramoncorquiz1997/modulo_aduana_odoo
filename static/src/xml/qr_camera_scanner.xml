<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
  <t t-name="modulo_aduana_odoo.QrCameraScannerAction">
    <div class="o_action o_qr_camera_scanner p-3">
      <h3 class="mb-2">
        <t t-esc="props.action.params.title || 'Escanear QR'"/>
      </h3>
      <p class="text-muted mb-2">Permite escanear desde escritorio o celular usando la cámara del navegador.</p>
      <div class="mb-3">
        <video t-ref="video"
               autoplay="1"
               playsinline="1"
               muted="1"
               style="width:100%;max-width:680px;min-height:260px;background:#000;border-radius:8px;"/>
        <canvas t-ref="canvas" style="display:none;"/>
      </div>
      <div class="mb-3">
        <label class="form-label">Resultado QR</label>
        <input class="form-control"
               type="text"
               t-model="state.result"
               t-on-input="onResultInput"
               placeholder="URL del QR"/>
      </div>
      <div t-if="state.error" class="alert alert-warning" role="alert">
        <t t-esc="state.error"/>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-primary" t-on-click="useResult">Guardar y validar</button>
        <button class="btn btn-secondary" t-on-click="startCamera">Reiniciar camara</button>
        <button class="btn btn-light" t-on-click="close">Cerrar</button>
      </div>
    </div>
  </t>
</templates>
