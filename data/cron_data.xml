<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <record id="cron_sync_tipo_cambio_banxico" model="ir.cron">
      <field name="name">Aduanex: Actualizar tipo de cambio FIX (Banxico)</field>
      <field name="model_id" ref="crm.model_crm_lead"/>
      <field name="state">code</field>
      <field name="code">model.cron_sync_tipo_cambio_banxico()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
      <field name="nextcall" eval="(DateTime.now().replace(hour=8, minute=0, second=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
      <field name="user_id" ref="base.user_root"/>
    </record>

  </data>
</odoo>
