<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="mail_template_portal_invite" model="mail.template">
      <field name="name">Portal Aduanex — Invitación de acceso</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="subject">Invitación al Portal de Clientes Aduanex</field>
      <field name="email_to">{{ object.email }}</field>
      <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <div style="background: #3D6332; padding: 30px; border-radius: 12px 12px 0 0; text-align: center;">
    <h1 style="color: white; margin: 0; font-size: 28px; font-style: italic;">
      Aduan<span style="color: #a8d08d;">ex</span>
    </h1>
    <p style="color: rgba(255,255,255,0.8); margin: 8px 0 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px;">
      Portal de Clientes
    </p>
  </div>

  <div style="background: #ffffff; padding: 40px; border: 1px solid #e2e8f0; border-top: none;">
    <p style="font-size: 16px; color: #374151;">Hola <strong>{{ object.name }}</strong>,</p>
    <p style="color: #6b7280; line-height: 1.6;">
      Has sido invitado a acceder al portal de clientes de <strong>Aduanex</strong>.
      Haz clic en el botón de abajo para crear tu contraseña y comenzar a gestionar
      tus operaciones.
    </p>

    <div style="text-align: center; margin: 32px 0;">
      <a href="{{ ctx.get('invite_url', '') }}"
         style="background: #3D6332; color: white; padding: 14px 32px; border-radius: 10px;
                text-decoration: none; font-weight: bold; font-size: 14px; letter-spacing: 1px;
                text-transform: uppercase; display: inline-block;">
        Crear mi contraseña
      </a>
    </div>

    <p style="color: #9ca3af; font-size: 12px; text-align: center;">
      Este link expira en <strong>48 horas</strong>.<br/>
      Si no puedes hacer clic, copia este enlace en tu navegador:
    </p>
    <p style="color: #3D6332; font-size: 11px; word-break: break-all; text-align: center;">
      {{ ctx.get('invite_url', '') }}
    </p>
  </div>

  <div style="background: #f8fafc; padding: 20px; border-radius: 0 0 12px 12px; text-align: center;">
    <p style="color: #9ca3af; font-size: 11px; margin: 0;">
      © 2026 Aduanex · Sistema de Gestión Logística
    </p>
  </div>
</div>
      ]]></field>
    </record>
  </data>
</odoo>
